PORT=3000
NODE_ENV=development
# Local dev uses a local MongoDB. For any hosted deployment (Render/Railway/etc.)
# use a MongoDB Atlas connection string instead — a cloud host cannot reach a DB
# on your laptop. Example: mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/prestige-men?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/prestige-men
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# SafePay (https://getsafepay.com) — get these from your merchant dashboard:
# sandbox: https://sandbox.api.getsafepay.com/dashboard/login
# live:    https://getsafepay.com/dashboard/login
# If any of these are blank, card/debit payments are reported as unavailable
# (see SafepayService.isConfigured) instead of attempting a doomed API call.
SAFEPAY_ENVIRONMENT=sandbox
SAFEPAY_API_KEY=
SAFEPAY_V1_SECRET=
SAFEPAY_WEBHOOK_SECRET=
# Public base URL SafePay redirects back to after checkout, e.g.
# https://<your-render-app>.onrender.com or http://localhost:3000 for local testing.
SAFEPAY_REDIRECT_BASE_URL=http://localhost:3000
# Flutter web origin the callback redirects the browser to on web (so web users
# resume the verify→success flow instead of being stranded on the HTML page).
# Falls back to FRONTEND_URL. Leave blank for mobile-only.
SAFEPAY_WEB_REDIRECT_URL=http://localhost:8080
